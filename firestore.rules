rules_version = '2';

// Fathom Firestore rules. Only Tool 3 (projections) uses Firestore, and only
// for the signed-in user's own data. Everything is scoped under users/{uid};
// no cross-user access is possible.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/projections/{ticker} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && validProjection(request.resource.data);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validProjection(d) {
  return d.ticker is string
    && d.ticker.size() > 0 && d.ticker.size() <= 12
    && d.inputs is map
    && d.inputs.baseRevenue is number
    && d.inputs.sharesOut is number
    && d.inputs.currentPrice is number
    && d.inputs.horizonYears is number
    && d.inputs.horizonYears >= 1 && d.inputs.horizonYears <= 30
    && d.scenarios is map
    && d.notes is string
    && d.notes.size() <= 5000
    && d.updatedAt is number;
}
